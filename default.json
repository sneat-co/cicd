{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "minimumReleaseAge": "1 day",
  "internalChecksFilter": "strict",
  "timezone": "Europe/Dublin",
  "schedule": [
    "0 4 * * *"
  ],
  "packageRules": [
    {
      "description": "Batch dependencies published from the Sneat-Co GitHub organization",
      "matchSourceUrls": [
        "https://github.com/sneat-co/**"
      ],
      "groupName": "sneat-co dependencies",
      "groupSlug": "sneat-co-dependencies"
    }
  ]
}
